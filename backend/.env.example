# Copy this file to .env and fill in your keys.
# cp .env.example .env

# -------- Chat: DeepSeek (OpenAI-compatible) --------
# Get a key at https://platform.deepseek.com
OPENAI_API_KEY=sk-your-deepseek-key-here
OPENAI_API_BASE=https://api.deepseek.com
# Recommended: deepseek-chat / deepseek-v4-flash / deepseek-v4-pro
OPENAI_CHAT_MODEL=deepseek-chat
# Model request timeout in seconds (frontend settings can override it per session)
OPENAI_TIMEOUT_SECONDS=30

# -------- Embedding --------
# DeepSeek 不提供 embeddings API。默认用本地模型；导入前请运行初始化命令。
# 可选值: local | openai_compatible
EMBEDDING_PROVIDER=local

# 仅当 EMBEDDING_PROVIDER=openai_compatible 时需要填写（例如 OpenAI / 其他兼容服务）
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Paper search
# auto = Semantic Scholar first, 429 时自动改用 arXiv（推荐）
# semanticscholar | arxiv
PAPER_SEARCH_SOURCE=auto
# Optional: higher S2 rate limits — https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
# Re-rank search hits by title + abstract similarity (not title-only)
SEARCH_RERANK=1
SEARCH_CANDIDATE_POOL=24

# App
APP_HOST=127.0.0.1
APP_PORT=8888
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage (relative to backend/)
SQLITE_PATH=./data/app.db
CHROMA_PATH=./data/chroma

# Retrieval
CHUNK_SIZE=900
CHUNK_OVERLAP=150
DEFAULT_TOP_K=8

# Literature survey pipeline (literature-review skill workflow)
# 0 = 单次生成；1 = 多视角→检索→大纲→终稿（默认）
SURVEY_PIPELINE=1
SURVEY_PERSONAS=3
SURVEY_QUERIES_PER_PERSONA=2
SURVEY_PERSONA_TOP_K=6

# Full-paper RAG: import 时自动下载开放获取 PDF（arXiv / S2 openAccessPdf）
FETCH_PDF_ON_IMPORT=true
PDF_MAX_CHARS=200000
# Local PDF upload limit in bytes (default 30 MiB)
PDF_UPLOAD_MAX_BYTES=31457280
# Batch import: parallel papers (keep modest to avoid arXiv timeouts)
IMPORT_CONCURRENCY=3
# Per-URL PDF download timeout (seconds) and retries
PDF_FETCH_TIMEOUT=45
PDF_FETCH_RETRIES=1
